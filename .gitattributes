# Ensure C/C++ source is treated as UTF-8 text with CRLF line endings on checkout
*.h    text eol=crlf
*.hpp  text eol=crlf
*.c    text eol=crlf
*.cc   text eol=crlf
*.cpp  text eol=crlf
*.cxx  text eol=crlf
*.ixx  text eol=crlf

# Project files
*.vcxproj          text eol=crlf
*.vcxproj.filters  text eol=crlf
*.sln              text eol=crlf
*.props            text eol=crlf

# Python / proto / data
*.py     text eol=lf
*.proto  text eol=lf
*.csv    text eol=lf
*.json   text eol=lf
*.md     text eol=lf

# Binary
*.exe  binary
*.dll  binary
*.lib  binary
*.pdb  binary
*.png  binary
*.jpg  binary
